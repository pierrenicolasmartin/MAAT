<Window x:Class="MAAT.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MAAT.App.Views"
        xmlns:vm="clr-namespace:MAAT.App.ViewModels"
        xmlns:l="clr-namespace:MAAT.App.Localization"
        Title="{l:Loc Win_Title}"
        Height="760" Width="1040" MinHeight="560" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/MAAT.App;component/Assets/maat.ico"
        Background="{DynamicResource BgBrush}"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate DataType="{x:Type vm:ScanViewModel}">
            <views:ScanView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- ===== Barre de menu ===== -->
        <Menu DockPanel.Dock="Top" Padding="8,3" Background="{DynamicResource HeaderBrush}">
            <MenuItem Header="{l:Loc Menu_File}">
                <MenuItem Header="{l:Loc Menu_NewAudit}" Command="{Binding NewAuditCommand}" />
                <MenuItem Header="{l:Loc Menu_OpenProject}" Command="{Binding OpenProjectCommand}" />
                <Separator />
                <MenuItem Header="{l:Loc Menu_ExportTo}" IsEnabled="{Binding HasResults}">
                    <MenuItem Header="{l:Loc Menu_ExportHtml}" Command="{Binding Workspace.ExportHtmlCommand}" />
                    <MenuItem Header="{l:Loc Menu_ExportCsv}" Command="{Binding Workspace.ExportCsvCommand}" />
                </MenuItem>
                <MenuItem Header="{l:Loc Menu_SaveProject}" IsEnabled="{Binding HasResults}"
                          Command="{Binding Workspace.SaveProjectCommand}" />
                <Separator />
                <MenuItem Header="{l:Loc Menu_Quit}" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="{l:Loc Menu_Preferences}">
                <MenuItem Header="{l:Loc Menu_Display}">
                    <MenuItem Header="{l:Loc Menu_ThemeAuto}" IsCheckable="True" IsChecked="{Binding IsThemeAuto, Mode=OneWay}"
                              Command="{Binding ThemeAutoCommand}" />
                    <Separator />
                    <MenuItem Header="{l:Loc Menu_ThemeLight}" IsCheckable="True" IsChecked="{Binding IsThemeLight, Mode=OneWay}"
                              Command="{Binding ThemeLightCommand}" />
                    <MenuItem Header="{l:Loc Menu_ThemeDark}" IsCheckable="True" IsChecked="{Binding IsThemeDark, Mode=OneWay}"
                              Command="{Binding ThemeDarkCommand}" />
                </MenuItem>
                <MenuItem Header="{l:Loc Menu_Language}">
                    <MenuItem Header="{l:Loc Menu_LangAuto}" IsCheckable="True" IsChecked="{Binding IsLangAuto, Mode=OneWay}"
                              Command="{Binding LanguageAutoCommand}" />
                    <Separator />
                    <MenuItem Header="Français" IsCheckable="True" IsChecked="{Binding IsLangFrench, Mode=OneWay}"
                              Command="{Binding LanguageFrenchCommand}" />
                    <MenuItem Header="English" IsCheckable="True" IsChecked="{Binding IsLangEnglish, Mode=OneWay}"
                              Command="{Binding LanguageEnglishCommand}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{l:Loc Menu_Help}">
                <MenuItem Header="{l:Loc Menu_Guide}" Command="{Binding GuideCommand}" />
                <Separator />
                <MenuItem Header="{l:Loc Menu_About}" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- ===== En-tête : mot-symbole, plat, filet inférieur ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,1" Padding="24,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{DynamicResource LogoSymbolImage}" Width="22" Height="22"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="MAÂT" FontFamily="Times New Roman, Times, serif" FontSize="17" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="7,0,0,0" Foreground="{DynamicResource TextBrush}" />
                    <Border Width="1" Height="16" Background="{DynamicResource BorderStrongBrush}" Margin="14,0" />
                    <TextBlock Text="{l:Loc Header_Subtitle}" FontSize="12.5" VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedBrush}" />
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource Label}"
                           Text="{l:Loc Header_Tag}" />
            </Grid>
        </Border>

        <!-- ===== Pied de page ===== -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,9">
            <Grid>
                <TextBlock Style="{StaticResource Muted}" Text="{Binding Workspace.ActionMessage}"
                           TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11.5"
                           Foreground="{DynamicResource TertiaryBrush}"
                           Text="{l:Loc Footer_Confidential}" />
            </Grid>
        </Border>

        <!-- ===== Corps : espace vide ou espace de travail ===== -->
        <Grid Margin="0">
            <!-- État vide : accueil sobre -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="540"
                        Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}">
                <Image Source="{DynamicResource LogoTexteImage}" Width="300" Stretch="Uniform"
                       HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Style="{StaticResource Display}" HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,28,0,0" Text="{l:Loc Empty_Title}" />
                <TextBlock Style="{StaticResource Muted}" HorizontalAlignment="Center" TextAlignment="Center"
                           FontSize="13.5" Margin="0,12,0,0" MaxWidth="440" TextWrapping="Wrap"
                           Text="{l:Loc Empty_Body}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,28,0,0">
                    <Button Content="{l:Loc Btn_NewAudit}" Padding="22,11" Margin="0,0,12,0" Command="{Binding NewAuditCommand}" />
                    <Button Content="{l:Loc Btn_OpenProject}" Style="{StaticResource GhostButton}" Padding="22,11"
                            Command="{Binding OpenProjectCommand}" />
                </StackPanel>
            </StackPanel>

            <!-- Espace de travail (scan / résultats) -->
            <ContentControl Content="{Binding Workspace}"
                            Visibility="{Binding HasWorkspace, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </DockPanel>
</Window>
