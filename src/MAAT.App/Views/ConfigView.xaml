<UserControl x:Class="MAAT.App.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MAAT.App.Converters"
             xmlns:l="clr-namespace:MAAT.App.Localization">
    <UserControl.Resources>
        <conv:EnumMatchConverter x:Key="EnumMatch" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Titre de bloc : grotesque -->
        <Style x:Key="StepTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontSans}" />
            <Setter Property="FontSize" Value="14.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <!-- Pastille « niveau N » : seule touche d'accent -->
        <Style x:Key="LvlPill" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="7,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>
        <Style x:Key="LvlNum" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Chemin (pleine largeur, compact) -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="20,16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource StepTitle}" Margin="0,0,0,8"
                           Text="{l:Loc Cfg_Folder}" />
                <TextBox Grid.Row="1" Grid.Column="0" Height="32" Padding="11,4"
                         Text="{Binding RootPath, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource GhostButton}" Margin="10,0,0,0"
                        Height="32" Padding="14,0" Content="{l:Loc Cfg_Browse}" Command="{Binding BrowseCommand}" />
                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource Muted}" Margin="0,7,0,0" FontSize="11.5"
                           Text="{l:Loc Cfg_FolderHint}" />
                <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Margin="0,4,0,0" Foreground="{DynamicResource DenyBrush}" FontSize="12"
                           TextWrapping="Wrap" Text="{Binding PathError}"
                           Visibility="{Binding HasPathError, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <!-- Deux colonnes -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Colonne gauche : profondeur -->
            <StackPanel Grid.Column="0" Margin="0,0,7,0">
                <Border Style="{StaticResource Card}" Padding="20,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StepTitle}" Text="{l:Loc Cfg_Depth}" />
                        <ComboBox ItemsSource="{Binding DepthOptions}" SelectedItem="{Binding SelectedDepth}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Schéma de la numérotation -->
                        <Border Margin="0,12,0,0" Background="{DynamicResource BgBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="13,10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Label}" Margin="0,0,0,7" Text="{l:Loc Cfg_Numbering}" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Foreground="{DynamicResource TextBrush}" Text="{l:Loc Cfg_Root}" VerticalAlignment="Center" FontSize="13" />
                                    <Border Style="{StaticResource LvlPill}"><TextBlock Style="{StaticResource LvlNum}" Text="0" /></Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="14,3,0,0">
                                    <TextBlock Foreground="{DynamicResource TertiaryBrush}" FontFamily="{StaticResource FontMono}" Text="└─" VerticalAlignment="Center" />
                                    <TextBlock Margin="8,0,0,0" Foreground="{DynamicResource TextBrush}" Text="{l:Loc Cfg_Subfolder}" VerticalAlignment="Center" FontSize="13" />
                                    <Border Style="{StaticResource LvlPill}"><TextBlock Style="{StaticResource LvlNum}" Text="1" /></Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="30,3,0,0">
                                    <TextBlock Foreground="{DynamicResource TertiaryBrush}" FontFamily="{StaticResource FontMono}" Text="└─" VerticalAlignment="Center" />
                                    <TextBlock Margin="8,0,0,0" Foreground="{DynamicResource TextBrush}" Text="{l:Loc Cfg_Subfolder}" VerticalAlignment="Center" FontSize="13" />
                                    <Border Style="{StaticResource LvlPill}"><TextBlock Style="{StaticResource LvlNum}" Text="2" /></Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="46,3,0,0">
                                    <TextBlock Foreground="{DynamicResource TertiaryBrush}" FontFamily="{StaticResource FontMono}" Text="└─ …" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource Muted}" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="11.5"
                                           Text="{l:Loc Cfg_DepthHint}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Colonne droite : type + contenu -->
            <StackPanel Grid.Column="1" Margin="7,0,0,0">
                <Border Style="{StaticResource Card}" Padding="20,16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StepTitle}" Text="{l:Loc Cfg_Type}" />
                        <RadioButton GroupName="scope"
                                     IsChecked="{Binding Scope, Converter={StaticResource EnumMatch}, ConverterParameter=FoldersOnly}">
                            <TextBlock Text="{l:Loc Cfg_TypeFolders}" />
                        </RadioButton>
                        <RadioButton GroupName="scope"
                                     IsChecked="{Binding Scope, Converter={StaticResource EnumMatch}, ConverterParameter=FoldersAndFiles}">
                            <StackPanel>
                                <TextBlock Text="{l:Loc Cfg_TypeFiles}" />
                                <TextBlock Style="{StaticResource Muted}" FontSize="11" Text="{l:Loc Cfg_LongHint}" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="20,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StepTitle}" Text="{l:Loc Cfg_Content}" />
                        <RadioButton GroupName="content" Content="{l:Loc Cfg_ContentRights}"
                                     IsChecked="{Binding Content, Converter={StaticResource EnumMatch}, ConverterParameter=RightsOnly}" />
                        <RadioButton GroupName="content" Content="{l:Loc Cfg_ContentSize}"
                                     IsChecked="{Binding Content, Converter={StaticResource EnumMatch}, ConverterParameter=SizeOnly}" />
                        <RadioButton GroupName="content" Content="{l:Loc Cfg_ContentBoth}"
                                     IsChecked="{Binding Content, Converter={StaticResource EnumMatch}, ConverterParameter=RightsAndSize}" />

                        <!-- Étendue des identités -->
                        <Border Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="13,11"
                                Margin="0,12,0,0" IsEnabled="{Binding AuditsRights}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Label}" Text="{l:Loc Cfg_IdScope}" />
                                <CheckBox Margin="0,8,0,0" IsChecked="{Binding IncludeLocalAccounts}"
                                          Content="{l:Loc Cfg_IncludeLocal}" />
                                <TextBlock Style="{StaticResource Muted}" Margin="27,4,0,0" TextWrapping="Wrap" FontSize="11.5"
                                           Text="{l:Loc Cfg_IncludeLocalHint}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
