<Window x:Class="MAAT.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MAAT.App.Localization"
        Title="{l:Loc About_WinTitle}"
        Width="520" SizeToContent="Height" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/MAAT.App;component/Assets/maat.ico"
        Background="{DynamicResource BgBrush}"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Étiquette monospace majuscule (kicker) -->
        <Style x:Key="Kicker" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Font.Mono}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource TertiaryBrush}" />
        </Style>
    </Window.Resources>

    <StackPanel>

        <!-- ═════════ En-tête : logotype (image, theme-aware) ═════════ -->
        <Border Background="{DynamicResource HeaderBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="40,30">
            <StackPanel VerticalAlignment="Center">
                <Image Source="{DynamicResource LogoTexteImage}" Height="56" Stretch="Uniform"
                       HorizontalAlignment="Left" RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="{l:Loc About_Subtitle}" FontFamily="{StaticResource Font.Sans}" FontSize="12.5"
                           Foreground="{DynamicResource MutedBrush}" Margin="2,16,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- ═════════ Corps ═════════ -->
        <Border Padding="40,28">
            <StackPanel>
                <!-- Version + édition -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="VersionText" FontFamily="{StaticResource Font.Serif}" FontSize="24"
                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                               TextOptions.TextFormattingMode="Ideal" />
                    <Border Width="22" Height="1" Background="{DynamicResource BorderStrongBrush}" Margin="14,0" VerticalAlignment="Center" />
                    <TextBlock Style="{StaticResource Kicker}" Text="{l:Loc About_Edition}" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Description -->
                <TextBlock Text="{l:Loc About_Tagline}" FontFamily="{StaticResource Font.Sans}" FontSize="14.5"
                           Foreground="{DynamicResource MutedBrush}" Margin="0,14,0,0" TextWrapping="Wrap" LineHeight="22" />

                <!-- Rangée de capacités -->
                <Border Margin="0,20,0,0" BorderBrush="{DynamicResource Card2Brush}" BorderThickness="0,1,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,14,14,14">
                            <TextBlock Style="{StaticResource Kicker}" FontSize="9.5" Text="{l:Loc About_Cap1Label}" />
                            <TextBlock Text="{l:Loc About_Cap1Value}" FontFamily="{StaticResource Font.Sans}" FontSize="13.5"
                                       Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" BorderBrush="{DynamicResource Card2Brush}" BorderThickness="1,0,0,0">
                            <StackPanel Margin="16,14,14,14">
                                <TextBlock Style="{StaticResource Kicker}" FontSize="9.5" Text="{l:Loc About_Cap2Label}" />
                                <TextBlock Text="{l:Loc About_Cap2Value}" FontFamily="{StaticResource Font.Sans}" FontSize="13.5"
                                           Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" BorderBrush="{DynamicResource Card2Brush}" BorderThickness="1,0,0,0">
                            <StackPanel Margin="16,14,0,14">
                                <TextBlock Style="{StaticResource Kicker}" FontSize="9.5" Text="{l:Loc About_Cap3Label}" />
                                <TextBlock Text="{l:Loc About_Cap3Value}" FontFamily="{StaticResource Font.Sans}" FontSize="13.5"
                                           Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Bloc licence -->
                <Grid Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="3" Background="{DynamicResource AccentBrush}" />
                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Style="{StaticResource Kicker}" FontSize="10.5" Foreground="{DynamicResource MutedBrush}"
                                   Text="{l:Loc About_License}" />
                        <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource Font.Sans}" FontSize="13.5"
                                   Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" LineHeight="21">
                            <Run Text="{l:Loc About_LicenseBody}" /><Hyperlink
                                NavigateUri="https://www.gnu.org/licenses/gpl-3.0.html" RequestNavigate="OnNavigate"
                                FontFamily="{StaticResource Font.Mono}" Foreground="{DynamicResource AccentBrush}"
                                >www.gnu.org/licenses/gpl-3.0.html</Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,10,0,0" FontFamily="{StaticResource Font.Sans}" FontSize="12"
                                   Foreground="{DynamicResource TertiaryBrush}" TextWrapping="Wrap" LineHeight="18"
                                   Text="{l:Loc About_Warranty}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ═════════ Pied ═════════ -->
        <Border Background="{DynamicResource HeaderBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="40,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="CopyrightText" FontFamily="{StaticResource Font.Sans}" FontSize="12.5"
                               Foreground="{DynamicResource MutedBrush}" />
                    <TextBlock Style="{StaticResource Kicker}" FontSize="9" Text="{l:Loc About_RightsReserved}" Margin="0,3,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="{l:Loc Common_Close}" MinWidth="96" Padding="20,9"
                        IsCancel="True" Click="OnClose" />
            </Grid>
        </Border>
    </StackPanel>
</Window>
