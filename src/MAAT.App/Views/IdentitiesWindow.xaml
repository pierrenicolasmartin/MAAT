<Window x:Class="MAAT.App.Views.IdentitiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MAAT.App.Localization"
        Title="{l:Loc Id_WinTitle}"
        Height="600" Width="640" MinHeight="400" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/MAAT.App;component/Assets/maat.ico"
        Background="{DynamicResource BgBrush}"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <DockPanel>
        <!-- En-tête -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,18">
            <StackPanel>
                <TextBlock Style="{StaticResource Label}" Text="{l:Loc Id_Label}" Margin="0,0,0,4" />
                <TextBlock Style="{StaticResource H1}" Text="{l:Loc Id_Title}" />
                <TextBlock Text="{Binding Summary}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Barre outils -->
        <Border DockPanel.Dock="Top" Padding="16,10" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}" />
                <Button Grid.Column="1" Margin="10,0,0,0" Style="{StaticResource GhostButton}"
                        Content="{l:Loc Id_ExportCsv}" Command="{Binding ExportCsvCommand}" />
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <!-- Groupes -->
                <TextBlock Text="{l:Loc Id_Groups}" Style="{StaticResource H2}" Margin="0,0,0,6"
                           Foreground="{DynamicResource AccentBrush}" />
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="1" CornerRadius="8" Margin="0,0,0,6" Padding="10,7">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource CardGradientBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Effect" Value="{DynamicResource GlowAccent}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <Button HorizontalContentAlignment="Stretch" Command="{Binding ToggleCommand}"
                                            Background="Transparent" Cursor="Hand" Padding="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Identity}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" Background="{DynamicResource Card2Brush}" CornerRadius="9" Padding="7,1" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding MembersToggleText}" FontSize="11" Foreground="{DynamicResource AccentBrush}" />
                                            </Border>
                                            <Border Grid.Column="2" Background="{DynamicResource Card2Brush}" CornerRadius="9" Padding="7,1" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding CountText}" FontSize="11" Foreground="{DynamicResource GreenBrush}" />
                                            </Border>
                                        </Grid>
                                    </Button>
                                    <ItemsControl ItemsSource="{Binding Members}" Margin="14,6,0,0"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Margin="0,2" Foreground="{DynamicResource MutedBrush}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Utilisateurs -->
                <TextBlock Text="{l:Loc Id_Users}" Style="{StaticResource H2}" Margin="0,14,0,6"
                           Foreground="{DynamicResource MutedBrush}" />
                <ItemsControl ItemsSource="{Binding Users}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="1" CornerRadius="8" Margin="0,0,0,6" Padding="10,7">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource CardGradientBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Effect" Value="{DynamicResource GlowAccent}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <TextBlock Text="{Binding Identity}" Foreground="{DynamicResource TextBrush}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <Border HorizontalAlignment="Right" Background="{DynamicResource Card2Brush}" CornerRadius="9" Padding="7,1">
                                        <TextBlock Text="{Binding CountText}" FontSize="11" Foreground="{DynamicResource GreenBrush}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
