<Window x:Class="MAAT.App.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MAAT.App.Views"
        xmlns:l="clr-namespace:MAAT.App.Localization"
        Title="{l:Loc Cfg_WinTitle}"
        Width="820" MinWidth="720" SizeToContent="Height" ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/MAAT.App;component/Assets/maat.ico"
        Background="{DynamicResource BgBrush}">
    <DockPanel>
        <!-- Barre de boutons -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource GhostButton}" Margin="0,0,10,0" Content="{l:Loc Common_Cancel}"
                        IsCancel="True" Click="OnCancel" />
                <Button Padding="22,10" Content="{l:Loc Cfg_Start}" Command="{Binding StartCommand}" />
            </StackPanel>
        </Border>

        <views:ConfigView />
    </DockPanel>
</Window>
