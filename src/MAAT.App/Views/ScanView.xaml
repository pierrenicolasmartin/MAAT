<UserControl x:Class="MAAT.App.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAAT.App.ViewModels"
             xmlns:beh="clr-namespace:MAAT.App.Behaviors"
             xmlns:l="clr-namespace:MAAT.App.Localization">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Carte statistique : surface plate, filet 1 px (renforcé au survol) -->
        <Style x:Key="StatBadge" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="MinWidth" Value="120" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BadgeValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== En-tête : chemin/date, statistiques, recherche, filtres ===== -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16" Padding="20,18">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource Mono}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"
                               Text="{Binding RootPath}" VerticalAlignment="Center" />
                    <Border Width="1" Height="13" Background="{DynamicResource BorderStrongBrush}" Margin="12,0" VerticalAlignment="Center" />
                    <TextBlock Style="{StaticResource Muted}" VerticalAlignment="Center">
                        <Run Text="{l:Loc Scan_AuditedPrefix}" /><Run Text=" " /><Run Text="{Binding AuditDateText, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>

                <!-- Statistiques -->
                <WrapPanel Margin="0,16,0,0">
                    <Border Style="{StaticResource StatBadge}">
                        <StackPanel>
                            <TextBlock Text="{Binding StatFolders}" Style="{StaticResource BadgeValue}" />
                            <TextBlock Text="{l:Loc Scan_Folders}" Style="{StaticResource Label}" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatBadge}" Visibility="{Binding ShowFilesStat, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{Binding StatFiles}" Style="{StaticResource BadgeValue}" />
                            <TextBlock Text="{l:Loc Scan_Files}" Style="{StaticResource Label}" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatBadge}" Visibility="{Binding ShowSizeStat, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{Binding StatSizeText}" Style="{StaticResource BadgeValue}" />
                            <TextBlock Text="{l:Loc Scan_TotalSize}" Style="{StaticResource Label}" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatBadge}" Visibility="{Binding ShowRightsStat, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{Binding StatAces}" Style="{StaticResource BadgeValue}" />
                            <TextBlock Text="{l:Loc Scan_Aces}" Style="{StaticResource Label}" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                    <!-- Carte Identités (cliquable) -->
                    <Button x:Name="IdentitiesCard" Click="OnIdentitiesClick" Cursor="Hand" Padding="0" BorderThickness="0"
                            Margin="0" Background="Transparent"
                            Visibility="{Binding ShowRightsStat, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="{DynamicResource CardBrush}" CornerRadius="6" Padding="16,12"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" MinWidth="120">
                                    <StackPanel>
                                        <TextBlock Text="{Binding StatIdentities}" Style="{StaticResource BadgeValue}" />
                                        <TextBlock x:Name="lbl" Text="{l:Loc Scan_Identities}" Style="{StaticResource Label}" Margin="0,5,0,0"
                                                   Foreground="{DynamicResource AccentBrush}" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentTintBrush}" />
                                        <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </WrapPanel>

                <!-- Recherche + filtres -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource CardBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="11,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Loupe monoline -->
                            <Canvas Grid.Column="0" Width="15" Height="15" Margin="0,0,9,0" VerticalAlignment="Center">
                                <Ellipse Canvas.Left="0" Canvas.Top="0" Width="10" Height="10"
                                         Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.4" />
                                <Line X1="9" Y1="9" X2="14" Y2="14" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                            <Grid Grid.Column="1">
                                <TextBox Style="{StaticResource SearchTextBox}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}" />
                                <TextBlock Text="{l:Loc Scan_Search}" IsHitTestVisible="False"
                                           VerticalAlignment="Center" Foreground="{DynamicResource TertiaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Column="1" Style="{StaticResource Muted}" VerticalAlignment="Center"
                               Margin="14,0,0,0" Text="{Binding SearchInfo}" />

                    <!-- Contrôle d'accès : éléments accessibles à une identité (direct ou via groupe AD) -->
                    <ComboBox Grid.Column="2" Margin="14,0,0,0" Width="210" VerticalContentAlignment="Center"
                              ToolTip="{l:Loc Scan_AccessTip}"
                              ItemsSource="{Binding AccessIdentities}"
                              SelectedItem="{Binding SelectedAccessIdentity}"
                              Visibility="{Binding ShowRightsStat, Converter={StaticResource BoolToVis}}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox Grid.Column="3" Margin="12,0,0,0" Width="150" VerticalContentAlignment="Center"
                              SelectedValuePath="Tag" SelectedValue="{Binding SelectedAclFilter}"
                              Visibility="{Binding ShowRightsStat, Converter={StaticResource BoolToVis}}">
                        <ComboBoxItem Content="{l:Loc Scan_AllRights}" Tag="{x:Static vm:AclFilter.All}" />
                        <ComboBoxItem Content="{l:Loc Scan_Explicit}" Tag="{x:Static vm:AclFilter.Explicit}" />
                        <ComboBoxItem Content="{l:Loc Scan_Inherited}" Tag="{x:Static vm:AclFilter.Inherited}" />
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ===== Arbre = résultat (ACL inline au clic) ===== -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
            <TreeView ItemsSource="{Binding Nodes}" BorderThickness="0" Background="Transparent"
                      VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                <TreeView.Resources>
                    <!-- Expandeur : chevron monoline qui pivote -->
                    <Style x:Key="ExpandToggle" TargetType="ToggleButton">
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="ClickMode" Value="Press" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" Width="18" Height="22">
                                        <Path x:Name="chev" Data="M0,0 L5,5 L0,10" Stroke="{DynamicResource TertiaryBrush}"
                                              StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="chev" Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="90" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="chev" Property="Stroke" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <DataTemplate DataType="{x:Type vm:LoadingPlaceholder}">
                        <TextBlock Style="{StaticResource Muted}" FontStyle="Italic" Text="{l:Loc Scan_Loading}" />
                    </DataTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}" ItemsSource="{Binding Children}">
                        <StackPanel>
                            <!-- Ligne de l'élément : barre de sélection corail + survol/sélection en teinte -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="selbar" Grid.Column="0" Background="Transparent" CornerRadius="1" Margin="0,1" />
                                <Border x:Name="rowBg" Grid.Column="1" CornerRadius="4" Padding="6,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentTintBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource LinkButton}" Command="{Binding ToggleAclCommand}"
                                                IsEnabled="{Binding CanShowAcl}" Foreground="{DynamicResource TextBrush}"
                                                ToolTip="{l:Loc Scan_AclTip}">
                                            <TextBlock beh:TextHighlight.Text="{Binding Label}"
                                                       beh:TextHighlight.Query="{Binding HighlightTerm}" />
                                        </Button>
                                        <!-- Capsule d'extension (neutre, uniforme) -->
                                        <Border CornerRadius="3" Padding="6,1" Margin="9,0,0,0" VerticalAlignment="Center"
                                                Background="{DynamicResource Card2Brush}"
                                                Visibility="{Binding HasExtension, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding ExtensionText}" FontSize="9.5" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TertiaryBrush}" />
                                        </Border>
                                        <TextBlock Text="{Binding SizeText}" FontFamily="{StaticResource FontMono}" FontSize="11.5"
                                                   Foreground="{DynamicResource MutedBrush}" Margin="10,0,0,0" VerticalAlignment="Center"
                                                   Visibility="{Binding HasSize, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Panneau ACL inline -->
                            <ItemsControl ItemsSource="{Binding AclLines}" Margin="14,4,0,6"
                                          Visibility="{Binding IsAclExpanded, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="11,8" Margin="0,0,0,5" BorderThickness="1"
                                                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BgBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding TypeText}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource GreenBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDeny}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource DenyBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="  " />
                                                    <TextBlock Text="{Binding Identity}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                                    <TextBlock Text="  —  " Foreground="{DynamicResource TertiaryBrush}" />
                                                    <TextBlock Text="{Binding RightsFr}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="{Binding ScopeFr}" Style="{StaticResource Muted}" />
                                                    <TextBlock Text=" · " Style="{StaticResource Muted}" />
                                                    <TextBlock Text="{Binding InheritedText}" Style="{StaticResource Muted}" />
                                                    <TextBlock Text=" · " Style="{StaticResource Muted}" />
                                                    <TextBlock Text="{Binding SourcePath}" Style="{StaticResource Muted}" FontStyle="Italic" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <!-- Membres au clic -->
                                                <Button Style="{StaticResource LinkButton}" Margin="0,4,0,0"
                                                        Command="{Binding ToggleMembersCommand}"
                                                        Visibility="{Binding HasMembers, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{Binding MembersToggleText}" Foreground="{DynamicResource AccentBrush}" FontSize="12" />
                                                </Button>
                                                <ItemsControl ItemsSource="{Binding MemberList}" Margin="14,4,0,0"
                                                              Visibility="{Binding IsMembersExpanded, Converter={StaticResource BoolToVis}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" Margin="0,1" FontSize="12" Foreground="{DynamicResource MutedBrush}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <HierarchicalDataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                <Setter TargetName="selbar" Property="Background" Value="{DynamicResource AccentBrush}" />
                            </DataTrigger>
                        </HierarchicalDataTemplate.Triggers>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton x:Name="Expander" Grid.Column="0" VerticalAlignment="Top" Margin="0,2,0,0"
                                                          Style="{StaticResource ExpandToggle}"
                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                                            <ContentPresenter Grid.Column="1" ContentSource="Header" />
                                        </Grid>
                                        <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="18,0,0,0" Visibility="Collapsed" />
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="True">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                        <Trigger Property="HasItems" Value="False">
                                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Border>
    </Grid>
</UserControl>
