<UserControl x:Class="MAAT.App.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAAT.App.ViewModels"
             xmlns:beh="clr-namespace:MAAT.App.Behaviors"
             xmlns:l="clr-namespace:MAAT.App.Localization">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Étiquette de colonne / kicker monospace majuscule -->
        <Style x:Key="ColLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Font.Mono}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource TertiaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Bouton de pagination (chevrons précédent / suivant) -->
        <Style x:Key="PagerButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource HeaderBrush}" BorderBrush="{DynamicResource BorderStrongBrush}"
                                BorderThickness="1" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Lien cliquable de cellule (Membres / Hérité) : pastille teintée au survol -->
        <Style x:Key="CellLink" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="4" Padding="6,2" Margin="-6,-2,0,-2">
                            <ContentPresenter VerticalAlignment="Center" TextBlock.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentTintBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton de segment (Dossiers / Identités) : actif = accent -->
        <Style x:Key="SegBtnBase" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource Font.Sans}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="5" Padding="16,7">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{StaticResource Font.Sans}" FontSize="13" FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═════════ Barre de contexte : chemin + date ═════════ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,0" MinHeight="42">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontFamily="{StaticResource Font.Mono}" FontWeight="Medium" FontSize="13"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Text="{Binding RootPath}" />
                <Border Grid.Column="1" Width="1" Height="14" Background="{DynamicResource BorderStrongBrush}" Margin="14,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Style="{StaticResource Muted}" FontSize="12" VerticalAlignment="Center">
                    <Run Text="{l:Loc Scan_AuditedPrefix}" /><Run Text=" " /><Run Text="{Binding AuditDateText, Mode=OneWay}" />
                </TextBlock>
            </Grid>
        </Border>

        <!-- ═════════ Bandeau de synthèse ═════════ -->
        <Border Grid.Row="1" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="20,12" MinWidth="120">
                    <TextBlock Text="{Binding StatFolders}" FontFamily="{StaticResource Font.Serif}" FontSize="21"
                               Foreground="{DynamicResource TextBrush}" TextOptions.TextFormattingMode="Ideal" />
                    <TextBlock Style="{StaticResource ColLabel}" Text="{l:Loc Scan_Folders}" Margin="0,4,0,0" />
                </StackPanel>
                <Border BorderBrush="{DynamicResource Card2Brush}" BorderThickness="1,0,0,0"
                        Visibility="{Binding ShowSizeStat, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="20,12" MinWidth="120">
                        <TextBlock Text="{Binding StatSizeText}" FontFamily="{StaticResource Font.Serif}" FontSize="21"
                                   Foreground="{DynamicResource TextBrush}" TextOptions.TextFormattingMode="Ideal" />
                        <TextBlock Style="{StaticResource ColLabel}" Text="{l:Loc Scan_TotalSize}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border BorderBrush="{DynamicResource Card2Brush}" BorderThickness="1,0,0,0"
                        Visibility="{Binding ShowRightsStat, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="20,12" MinWidth="120">
                        <TextBlock Text="{Binding StatAces}" FontFamily="{StaticResource Font.Serif}" FontSize="21"
                                   Foreground="{DynamicResource TextBrush}" TextOptions.TextFormattingMode="Ideal" />
                        <TextBlock Style="{StaticResource ColLabel}" Text="{l:Loc Scan_Aces}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border BorderBrush="{DynamicResource Card2Brush}" BorderThickness="1,0,0,0"
                        Visibility="{Binding ShowRightsStat, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="20,12" MinWidth="120">
                        <TextBlock Text="{Binding StatIdentities}" FontFamily="{StaticResource Font.Serif}" FontSize="21"
                                   Foreground="{DynamicResource TextBrush}" TextOptions.TextFormattingMode="Ideal" />
                        <TextBlock Style="{StaticResource ColLabel}" Text="{l:Loc Scan_Identities}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═════════ Barre d'outils : recherche + segment + filtre ═════════ -->
        <Border Grid.Row="2" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Recherche -->
                <Border Grid.Column="0" Background="{DynamicResource HeaderBrush}" BorderThickness="1" CornerRadius="6" Padding="11,7">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Canvas Grid.Column="0" Width="15" Height="15" Margin="0,0,9,0" VerticalAlignment="Center">
                            <Ellipse Canvas.Left="0" Canvas.Top="0" Width="10" Height="10" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.4" />
                            <Line X1="9" Y1="9" X2="14" Y2="14" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                        <Grid Grid.Column="1">
                            <TextBox Style="{StaticResource SearchTextBox}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}" />
                            <TextBlock Text="{Binding SearchPlaceholder}" IsHitTestVisible="False" TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" Foreground="{DynamicResource TertiaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Segment Dossiers / Identités -->
                <Border Grid.Column="1" Margin="14,0,0,0" Background="{DynamicResource HeaderBrush}"
                        BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1" CornerRadius="6" Padding="3"
                        Visibility="{Binding ShowRightsStat, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{l:Loc Scan_SegFolders}" Command="{Binding ShowFoldersCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SegBtnBase}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                                    <Setter Property="FontWeight" Value="Normal" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsFoldersView}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                            <Setter Property="Foreground" Value="#FBF6F1" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{l:Loc Scan_SegIdentities}" Command="{Binding ShowIdentitiesCommand}" Margin="3,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SegBtnBase}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                                    <Setter Property="FontWeight" Value="Normal" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsIdentitiesView}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                            <Setter Property="Foreground" Value="#FBF6F1" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Filtre des droits -->
                <ComboBox Grid.Column="2" Margin="12,0,0,0" Width="150" VerticalContentAlignment="Center"
                          SelectedValuePath="Tag" SelectedValue="{Binding SelectedAclFilter}"
                          Visibility="{Binding ShowRightsStat, Converter={StaticResource BoolToVis}}">
                    <ComboBoxItem Content="{l:Loc Scan_AllRights}" Tag="{x:Static vm:AclFilter.All}" />
                    <ComboBoxItem Content="{l:Loc Scan_Explicit}" Tag="{x:Static vm:AclFilter.Explicit}" />
                    <ComboBoxItem Content="{l:Loc Scan_Inherited}" Tag="{x:Static vm:AclFilter.Inherited}" />
                </ComboBox>
            </Grid>
        </Border>

        <!-- ═════════ Corps : maître-détail ═════════ -->
        <Grid Grid.Row="3">
            <!-- ───── Vue Dossiers ───── -->
            <Grid Visibility="{Binding IsFoldersView, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="FoldersPaneColumn" Width="320" MinWidth="240" MaxWidth="640" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Maître : arbre -->
                <Border Grid.Column="0" Background="{DynamicResource HeaderBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <TreeView ItemsSource="{Binding Nodes}" BorderThickness="0" Background="Transparent" Padding="6,8"
                              SelectedItemChanged="OnTreeSelected" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <TreeView.Resources>
                            <Style x:Key="ExpandToggle" TargetType="ToggleButton">
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="ClickMode" Value="Press" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" Width="18" Height="22">
                                                <Path x:Name="chev" Data="M0,0 L5,5 L0,10" Stroke="{DynamicResource MutedBrush}"
                                                      StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="chev" Property="RenderTransform"><Setter.Value><RotateTransform Angle="90" /></Setter.Value></Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="chev" Property="Stroke" Value="{DynamicResource AccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <DataTemplate DataType="{x:Type vm:LoadingPlaceholder}">
                                <TextBlock Style="{StaticResource Muted}" FontStyle="Italic" Text="{l:Loc Scan_Loading}" />
                            </DataTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}" ItemsSource="{Binding Children}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="selbar" Grid.Column="0" Background="Transparent" CornerRadius="1" Margin="0,1" />
                                    <Border x:Name="rowBg" Grid.Column="1" CornerRadius="4" Padding="6,3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentTintBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" beh:TextHighlight.Text="{Binding Label}" beh:TextHighlight.Query="{Binding HighlightTerm}"
                                                       Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontFamily="{StaticResource Font.Mono}" FontSize="11"
                                                       Foreground="{DynamicResource TertiaryBrush}" Margin="10,0,0,0" VerticalAlignment="Center"
                                                       Visibility="{Binding HasSize, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                    </Border>
                                </Grid>
                                <HierarchicalDataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                        <Setter TargetName="selbar" Property="Background" Value="{DynamicResource AccentBrush}" />
                                        <Setter TargetName="rowBg" Property="Background" Value="{DynamicResource AccentTintBrush}" />
                                    </DataTrigger>
                                </HierarchicalDataTemplate.Triggers>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <ToggleButton x:Name="Expander" Grid.Column="0" VerticalAlignment="Top" Margin="0,2,0,0"
                                                                  Style="{StaticResource ExpandToggle}"
                                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                                                    <ContentPresenter Grid.Column="1" ContentSource="Header" />
                                                </Grid>
                                                <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="18,0,0,0" Visibility="Collapsed" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="True">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                                </Trigger>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Border>

                <!-- Poignée -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Cursor="SizeWE"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" DragCompleted="OnSplitterDragCompleted"
                              Background="{DynamicResource BorderBrush}">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>

                <!-- Détail dossier -->
                <Grid Grid.Column="2" Background="{DynamicResource BgBrush}">
                    <!-- Placeholder -->
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{l:Loc Scan_SelectFolder}"
                               Foreground="{DynamicResource MutedBrush}" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedFolder}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DockPanel Visibility="{Binding HasSelectedFolder, Converter={StaticResource BoolToVis}}" Margin="28,22">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="{Binding SelectedFolderName}" FontFamily="{StaticResource Font.Serif}" FontSize="22"
                                       Foreground="{DynamicResource TextBrush}" TextOptions.TextFormattingMode="Ideal" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedFolderPath}" FontFamily="{StaticResource Font.Mono}" FontSize="11.5"
                                       Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedFolderSummary}" FontFamily="{StaticResource Font.Mono}" FontSize="11.5"
                                       Foreground="{DynamicResource TertiaryBrush}" Margin="0,8,0,14" />
                        </StackPanel>

                        <!-- Table d'ACL -->
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                            <DockPanel>
                                <!-- En-tête de colonnes -->
                                <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBrush}" Padding="12,9"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="1.7*" />
                                            <ColumnDefinition Width="1.4*" />
                                            <ColumnDefinition Width="96" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColType}" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColIdentity}" />
                                        <TextBlock Grid.Column="2" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColMembers}" />
                                        <TextBlock Grid.Column="3" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColRights}" />
                                        <TextBlock Grid.Column="4" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColScope}" />
                                        <TextBlock Grid.Column="5" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColInherit}" />
                                    </Grid>
                                </Border>
                                <!-- Lignes -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SelectedAcl}" AlternationCount="2">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Card2Brush}" />
                                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="1">
                                                                    <Setter Property="Background" Value="{DynamicResource BgBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <Grid Margin="12,9">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="92" />
                                                                <ColumnDefinition Width="1.5*" />
                                                                <ColumnDefinition Width="64" />
                                                                <ColumnDefinition Width="1.7*" />
                                                                <ColumnDefinition Width="1.4*" />
                                                                <ColumnDefinition Width="96" />
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Type -->
                                                            <TextBlock Grid.Column="0" Text="{Binding TypeText}" FontFamily="{StaticResource Font.Mono}"
                                                                       FontSize="12" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource GreenBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDeny}" Value="True">
                                                                                <Setter Property="Foreground" Value="{DynamicResource DenyBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <!-- Identité -->
                                                            <TextBlock Grid.Column="1" Text="{Binding Identity}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                                                                       VerticalAlignment="Center" Margin="0,0,8,0" TextTrimming="CharacterEllipsis" />
                                                            <!-- Membres -->
                                                            <ContentControl Grid.Column="2" VerticalAlignment="Center">
                                                                <Button Style="{StaticResource CellLink}" Command="{Binding ToggleMembersCommand}"
                                                                        Visibility="{Binding HasMembers, Converter={StaticResource BoolToVis}}">
                                                                    <TextBlock Text="{Binding MemberCountText}" FontSize="12.5" />
                                                                </Button>
                                                            </ContentControl>
                                                            <TextBlock Grid.Column="2" Text="—" Foreground="{DynamicResource TertiaryBrush}" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasMembers}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <!-- Autorisations -->
                                                            <TextBlock Grid.Column="3" Text="{Binding RightsFr}" Foreground="{DynamicResource TextBrush}"
                                                                       VerticalAlignment="Center" Margin="0,0,8,0" TextWrapping="Wrap" />
                                                            <!-- Portée -->
                                                            <TextBlock Grid.Column="4" Text="{Binding ScopeFr}" Foreground="{DynamicResource MutedBrush}"
                                                                       VerticalAlignment="Center" Margin="0,0,8,0" TextWrapping="Wrap" />
                                                            <!-- Héritage -->
                                                            <ContentControl Grid.Column="5" VerticalAlignment="Center">
                                                                <Grid>
                                                                    <Button Style="{StaticResource CellLink}" Command="{Binding ToggleSourceCommand}"
                                                                            Visibility="{Binding IsInherited, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Text="{Binding InheritedText}" FontSize="12" />
                                                                    </Button>
                                                                    <TextBlock Text="{Binding InheritedText}" Foreground="{DynamicResource TertiaryBrush}" FontSize="12" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsInherited}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </ContentControl>
                                                        </Grid>

                                                        <!-- Panneau membres -->
                                                        <Border Background="{DynamicResource HeaderBrush}" Margin="12,0,12,10" Padding="12,10" CornerRadius="5"
                                                                Visibility="{Binding IsMembersExpanded, Converter={StaticResource BoolToVis}}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding MembersPanelLabel}" Style="{StaticResource ColLabel}" Margin="0,0,0,6" />
                                                                <ItemsControl ItemsSource="{Binding MemberPreview}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Margin="0,2">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="›" Foreground="{DynamicResource TertiaryBrush}" Margin="0,0,8,0" />
                                                                                <TextBlock Grid.Column="1" Text="{Binding}" FontFamily="{StaticResource Font.Mono}" FontSize="12"
                                                                                           Foreground="{DynamicResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Text="{Binding MoreMembersText}" FontFamily="{StaticResource Font.Mono}" FontSize="11.5"
                                                                           Foreground="{DynamicResource TertiaryBrush}" Margin="16,4,0,0"
                                                                           Visibility="{Binding HasMoreMembers, Converter={StaticResource BoolToVis}}" />
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Panneau source d'héritage -->
                                                        <Border Background="{DynamicResource HeaderBrush}" Margin="12,0,12,10" Padding="12,10" CornerRadius="5"
                                                                Visibility="{Binding IsSourceExpanded, Converter={StaticResource BoolToVis}}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding InheritedFromLabel}" Style="{StaticResource ColLabel}" Margin="0,0,0,5" />
                                                                <TextBlock Text="{Binding SourcePath}" FontFamily="{StaticResource Font.Mono}" FontSize="12"
                                                                           Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </DockPanel>
                </Grid>
            </Grid>

            <!-- ───── Vue Identités ───── -->
            <Grid Visibility="{Binding IsIdentitiesView, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="IdentitiesPaneColumn" Width="320" MinWidth="240" MaxWidth="640" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Maître : liste d'identités -->
                <Border Grid.Column="0" Background="{DynamicResource HeaderBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="16,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding IdentitiesCountText}" Style="{StaticResource ColLabel}" />
                        </Border>
                        <ListBox ItemsSource="{Binding Identities}" SelectedItem="{Binding SelectedIdentity}"
                                 Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border x:Name="sel" Grid.Column="0" Background="Transparent" />
                                                    <Border x:Name="bg" Grid.Column="1" Background="Transparent" Padding="12,9">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Marker}" Foreground="{DynamicResource AccentBrush}"
                                                                       FontSize="11" VerticalAlignment="Top" Margin="0,2,10,0" />
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Identity}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding FolderCountText}" FontFamily="{StaticResource Font.Mono}" FontSize="10.5"
                                                                           Foreground="{DynamicResource TertiaryBrush}" Margin="0,2,0,0" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentTintBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentTintBrush}" />
                                                        <Setter TargetName="sel" Property="Background" Value="{DynamicResource AccentBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Cursor="SizeWE"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" DragCompleted="OnSplitterDragCompleted"
                              Background="{DynamicResource BorderBrush}">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>

                <!-- Détail identité -->
                <Grid Grid.Column="2" Background="{DynamicResource BgBrush}">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{l:Loc Scan_SelectIdentity}"
                               Foreground="{DynamicResource MutedBrush}" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedIdentity}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DockPanel Margin="28,22" DataContext="{Binding SelectedIdentityDetail}"
                               Visibility="{Binding DataContext.HasSelectedIdentity, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
                        <!-- En-tête -->
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="{Binding Identity}" FontFamily="{StaticResource Font.Serif}" FontSize="22"
                                       Foreground="{DynamicResource TextBrush}" TextOptions.TextFormattingMode="Ideal" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding TypeText}" FontFamily="{StaticResource Font.Mono}" FontSize="11"
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,5,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="{Binding MembersCountText}" FontFamily="{StaticResource Font.Mono}" FontSize="11.5"
                                           Foreground="{DynamicResource TertiaryBrush}" Visibility="{Binding HasMembers, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="  │  " FontFamily="{StaticResource Font.Mono}" FontSize="11.5" Foreground="{DynamicResource BorderStrongBrush}"
                                           Visibility="{Binding HasMembers, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{Binding PresentOnText}" FontFamily="{StaticResource Font.Mono}" FontSize="11.5"
                                           Foreground="{DynamicResource TertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Membres du groupe (encadré plafonné) -->
                        <Border DockPanel.Dock="Top" Margin="0,16,0,0" MaxHeight="180"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                                Visibility="{Binding HasMembers, Converter={StaticResource BoolToVis}}">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBrush}" Padding="12,9"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <TextBlock Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColMembers}" />
                                </Border>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Members}" Padding="12,8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="›" Foreground="{DynamicResource TertiaryBrush}" Margin="0,0,8,0" />
                                                    <TextBlock Grid.Column="1" Text="{Binding}" FontFamily="{StaticResource Font.Mono}" FontSize="12"
                                                               Foreground="{DynamicResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- Emplacements (table paginée) -->
                        <Border Margin="0,16,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" ClipToBounds="True"
                                Visibility="{Binding HasLocations, Converter={StaticResource BoolToVis}}">
                            <DockPanel>
                                <!-- En-tête de colonnes -->
                                <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBrush}" Padding="12,9"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="1.6*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="84" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColPath}" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColType}" />
                                        <TextBlock Grid.Column="2" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColRights}" />
                                        <TextBlock Grid.Column="3" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColScope}" />
                                        <TextBlock Grid.Column="4" Style="{StaticResource ColLabel}" Text="{l:Loc Scan_ColInherit}" />
                                    </Grid>
                                </Border>

                                <!-- Pagination -->
                                <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBrush}" Padding="12,8"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding RangeText}" FontFamily="{StaticResource Font.Mono}" FontSize="11.5"
                                                   Foreground="{DynamicResource TertiaryBrush}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="{l:Loc Scan_PerPage}" Style="{StaticResource ColLabel}" Margin="0,0,8,0" />
                                            <ComboBox Width="66" VerticalContentAlignment="Center"
                                                      ItemsSource="{x:Static vm:IdentityDetailViewModel.PageSizes}"
                                                      SelectedItem="{Binding PageSize}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource PagerButton}" Command="{Binding PrevPageCommand}">
                                                <Path Data="M5,0 L0,5 L5,10" Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                            </Button>
                                            <Button Style="{StaticResource PagerButton}" Command="{Binding NextPageCommand}" Margin="6,0,0,0">
                                                <Path Data="M0,0 L5,5 L0,10" Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Lignes -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Locations}" AlternationCount="2">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Card2Brush}" />
                                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="1">
                                                                    <Setter Property="Background" Value="{DynamicResource BgBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid Margin="12,9">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2.2*" />
                                                            <ColumnDefinition Width="80" />
                                                            <ColumnDefinition Width="1.6*" />
                                                            <ColumnDefinition Width="1.2*" />
                                                            <ColumnDefinition Width="84" />
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Chemin -->
                                                        <TextBlock Grid.Column="0" Text="{Binding FullPath}" ToolTip="{Binding FullPath}"
                                                                   FontFamily="{StaticResource Font.Mono}" FontSize="11.5" Foreground="{DynamicResource TextBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0" TextTrimming="CharacterEllipsis" />
                                                        <!-- Type -->
                                                        <TextBlock Grid.Column="1" Text="{Binding TypeText}" FontFamily="{StaticResource Font.Mono}"
                                                                   FontSize="12" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource GreenBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDeny}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource DenyBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <!-- Autorisations -->
                                                        <TextBlock Grid.Column="2" Text="{Binding RightsFr}" Foreground="{DynamicResource TextBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0" TextWrapping="Wrap" />
                                                        <!-- Portée -->
                                                        <TextBlock Grid.Column="3" Text="{Binding ScopeFr}" Foreground="{DynamicResource MutedBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0" TextWrapping="Wrap" />
                                                        <!-- Héritage -->
                                                        <TextBlock Grid.Column="4" Text="{Binding InheritedText}" FontSize="12" Foreground="{DynamicResource TertiaryBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </DockPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
