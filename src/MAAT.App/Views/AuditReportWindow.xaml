<Window x:Class="MAAT.App.Views.AuditReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MAAT.App.Localization"
        Title="{l:Loc Rep_WinTitle}"
        Height="660" Width="740" MinHeight="480" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/MAAT.App;component/Assets/maat.ico"
        Background="{DynamicResource BgBrush}"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <DockPanel>
        <!-- En-tête éditorial -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,22">
            <StackPanel>
                <TextBlock Style="{StaticResource Label}" Text="{l:Loc Rep_Label}" Margin="0,0,0,4" />
                <TextBlock Style="{StaticResource H1}" Text="{l:Loc Rep_Title}" />
                <TextBlock Style="{StaticResource Mono}" Text="{Binding RootPath}" Foreground="{DynamicResource MutedBrush}"
                           Margin="0,8,0,0" TextTrimming="CharacterEllipsis" />
                <TextBlock Style="{StaticResource Muted}" Margin="0,3,0,0" FontSize="11.5">
                    <Run Text="{l:Loc Rep_FinishedOn}" /><Run Text="{Binding AuditDate, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Barre d'actions -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding ExportMessage}" VerticalAlignment="Center"
                           Foreground="{DynamicResource GreenBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{l:Loc Rep_ExportLog}" Style="{StaticResource GhostButton}" Command="{Binding ExportLogCommand}" />
                    <Button Content="{l:Loc Common_Close}" MinWidth="92" Margin="10,0,0,0" Click="OnClose" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20">
            <StackPanel>
                <!-- Statistiques -->
                <TextBlock Style="{StaticResource Label}" Text="{l:Loc Rep_Summary}" Margin="0,0,0,12" />
                <ItemsControl ItemsSource="{Binding Stats}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6" Margin="0,0,12,12" Padding="16,14" MinWidth="158"
                                    BorderThickness="1" Background="{DynamicResource CardBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAlert}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource DenyBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding Value}" FontFamily="{StaticResource FontDisplay}"
                                               FontSize="27" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding Label}" Style="{StaticResource Label}" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Éléments non audités -->
                <TextBlock Style="{StaticResource Label}" Text="{l:Loc Rep_Issues}" Margin="0,18,0,6" />
                <TextBlock Text="{Binding IssuesSummary}" Style="{StaticResource Muted}" Margin="0,0,0,10" TextWrapping="Wrap" />

                <!-- Aucun problème -->
                <Border Visibility="{Binding NoIssues, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource CardBrush}" CornerRadius="6" Padding="14,12"
                        BorderBrush="{DynamicResource GreenBrush}" BorderThickness="1">
                    <TextBlock Text="{l:Loc Rep_NoIssues}" Foreground="{DynamicResource TextBrush}" />
                </Border>

                <!-- Liste des problèmes -->
                <ItemsControl ItemsSource="{Binding Issues}"
                              Visibility="{Binding HasIssues, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="6" Margin="0,0,0,6"
                                    Padding="14,11" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Badge de gravité -->
                                        <Border CornerRadius="3" Padding="7,2" VerticalAlignment="Center"
                                                Background="{DynamicResource Card2Brush}">
                                            <TextBlock Text="{Binding Type}" FontSize="10.5" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource DenyBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="{Binding Path}" Margin="10,0,0,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"
                                                   FontFamily="{StaticResource FontMono}" FontSize="12" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
