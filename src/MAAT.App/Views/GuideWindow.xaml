<Window x:Class="MAAT.App.Views.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MAAT.App.Localization"
        Title="{l:Loc Guide_WinTitle}"
        Height="720" Width="760" MinHeight="500" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/MAAT.App;component/Assets/maat.ico"
        Background="{DynamicResource BgBrush}"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <Style x:Key="GLabel" TargetType="TextBlock" BasedOn="{StaticResource Label}">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="GTitle" TargetType="TextBlock" BasedOn="{StaticResource H3}">
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="GBody" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="GCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- En-tête -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,22">
            <StackPanel>
                <TextBlock Style="{StaticResource Label}" Text="{l:Loc Guide_HdrLabel}" Margin="0,0,0,4" />
                <TextBlock Style="{StaticResource H1}" Text="{l:Loc Guide_HdrTitle}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,0" Text="{l:Loc Guide_HdrSub}" />
            </StackPanel>
        </Border>

        <!-- Pied -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,12">
            <Button HorizontalAlignment="Right" Content="{l:Loc Common_Close}" MinWidth="92" IsCancel="True" Click="OnClose" />
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20">
            <StackPanel>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S1Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S1Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S1Body}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S2Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S2Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S2Body}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S3Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S3Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S3Body}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S4Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S4Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S4Body}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S5Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S5Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S5Body}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S6Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S6Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S6Body}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S7Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S7Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S7Body}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S8Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S8Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S8Body}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S9Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S9Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S9Body}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S10Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S10Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S10Body}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GLabel}" Text="{l:Loc Guide_S11Label}" />
                        <TextBlock Style="{StaticResource GTitle}" Text="{l:Loc Guide_S11Title}" />
                        <TextBlock Style="{StaticResource GBody}" Text="{l:Loc Guide_S11Body}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
