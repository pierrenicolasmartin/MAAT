<Window x:Class="MAAT.App.Views.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:MAAT.App.Localization"
        Title="Audit en cours — MAAT"
        Width="600" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Icon="pack://application:,,,/MAAT.App;component/Assets/maat.ico"
        Background="{DynamicResource BgBrush}"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Pastille verte translucide des étapes terminées (rgba(160,181,126,.2)) -->
        <SolidColorBrush x:Key="StepDoneTint" Color="#33A0B57E" />
    </Window.Resources>

    <!-- Carte flottante avec ombre portée prononcée -->
    <Border Background="{DynamicResource CardBrush}" CornerRadius="3" Margin="16"
            Padding="28,26" Effect="{DynamicResource GlowSoft}">
        <StackPanel>

            <!-- ───────── En-tête : titre + chemin / gros pourcentage ───────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                    <TextBlock Text="{l:Loc Prog_Title}" FontFamily="{StaticResource Font.Serif}"
                               FontSize="26" Foreground="{DynamicResource TextBrush}"
                               TextOptions.TextFormattingMode="Ideal" />
                    <TextBlock Text="{Binding RootPath}" FontFamily="{StaticResource Font.Mono}"
                               FontSize="13" Foreground="{DynamicResource MutedBrush}"
                               Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="16,0,0,0">
                    <TextBlock Text="{Binding GlobalPercentNumber}" FontFamily="{StaticResource Font.Serif}"
                               FontSize="40" Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Bottom" TextOptions.TextFormattingMode="Ideal" />
                    <TextBlock Text="%" FontFamily="{StaticResource Font.Serif}" FontSize="20"
                               Foreground="{DynamicResource MutedBrush}" Margin="3,0,0,4"
                               VerticalAlignment="Bottom" TextOptions.TextFormattingMode="Ideal" />
                </StackPanel>
            </Grid>

            <!-- ───────── Barre de progression globale ───────── -->
            <ProgressBar Height="6" Margin="0,14,0,22" Background="{DynamicResource BorderStrongBrush}"
                         Value="{Binding GlobalPercent, Mode=OneWay}" />

            <!-- ───────── Liste des étapes (dynamique) ───────── -->
            <ItemsControl ItemsSource="{Binding Steps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,11">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Indicateur d'état (cercle 20px) -->
                                <Grid Grid.Column="0" Width="20" Height="20" VerticalAlignment="Top">
                                    <Border x:Name="ring" Width="20" Height="20" CornerRadius="10"
                                            BorderThickness="2" BorderBrush="{DynamicResource BorderStrongBrush}"
                                            Background="Transparent" />
                                    <Border x:Name="doneDot" Width="20" Height="20" CornerRadius="10"
                                            Background="{StaticResource StepDoneTint}" Visibility="Collapsed">
                                        <TextBlock Text="✓" FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource GreenBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>

                                <!-- Libellé + statut/compteur + sous-barre -->
                                <StackPanel Grid.Column="2">
                                    <Grid>
                                        <TextBlock x:Name="lbl" Text="{Binding Label}"
                                                   FontFamily="{StaticResource Font.Sans}" FontSize="14"
                                                   Foreground="{DynamicResource TertiaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock x:Name="statusTb" HorizontalAlignment="Right"
                                                   Text="{Binding RightStatus}"
                                                   FontFamily="{StaticResource Font.Mono}" FontSize="12.5"
                                                   Foreground="{DynamicResource TertiaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock x:Name="countTb" HorizontalAlignment="Right" Visibility="Collapsed"
                                                   Text="{Binding CountText}"
                                                   FontFamily="{StaticResource Font.Mono}" FontSize="12.5"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <ProgressBar x:Name="sub" Height="5" Margin="0,8,0,0" Visibility="Collapsed"
                                                 Background="{DynamicResource BorderStrongBrush}"
                                                 Value="{Binding StepPercent, Mode=OneWay}"
                                                 IsIndeterminate="{Binding StepIndeterminate, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataTemplate.Triggers>
                                <!-- Étape active : cercle creux accent, libellé gras, compteur + sous-barre -->
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter TargetName="ring" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    <Setter TargetName="lbl" Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Setter TargetName="lbl" Property="FontWeight" Value="SemiBold" />
                                    <Setter TargetName="statusTb" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="countTb" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="sub" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <!-- Étape terminée : pastille pleine + coche verte, libellé atténué -->
                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                    <Setter TargetName="ring" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="doneDot" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="lbl" Property="Foreground" Value="{DynamicResource MutedBrush}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <!-- Filet de clôture (la dernière étape porte aussi un filet en bas) -->
            <Border Height="1" Background="{DynamicResource BorderBrush}" />

            <!-- ───────── Pied : minuteur + bouton Annuler ───────── -->
            <Grid Margin="0,22,0,0">
                <TextBlock Text="{Binding TimingText}" FontFamily="{StaticResource Font.Mono}"
                           FontSize="12.5" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" />
                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                        Content="{l:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
