<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ════════════════════════════════════════════════════════════
         MAAT — Thème PAPER (clair, primaire)
         Swiss design × Anthropic : papier ivoire chaud, encre, un seul
         accent corail. Surfaces plates, filets 1 px, aucun glow.
         Les CLÉS sont communes au thème Ink (bascule à chaud).
         ════════════════════════════════════════════════════════════ -->

    <!-- ── Fond / surfaces ── -->
    <Color x:Key="BgColor">#F4F1E9</Color>        <!-- canvas (ivoire chaud) -->
    <Color x:Key="CardColor">#FBFAF6</Color>       <!-- surface -->
    <Color x:Key="Card2Color">#ECE8DD</Color>      <!-- inset / pastilles neutres -->
    <Color x:Key="BorderColor">#E4DFD3</Color>     <!-- filet (hairline) -->
    <Color x:Key="BorderStrongColor">#CFC9BA</Color>
    <Color x:Key="HeaderColor">#EFEBE0</Color>     <!-- zone d'en-tête -->

    <!-- ── Texte ── -->
    <Color x:Key="TextColor">#1A1915</Color>       <!-- encre -->
    <Color x:Key="MutedColor">#6B675E</Color>      <!-- secondaire -->
    <Color x:Key="TertiaryColor">#98938A</Color>   <!-- légendes -->
    <Color x:Key="HeaderTextColor">#1A1915</Color>

    <!-- ── Accent unique (corail Anthropic) + fonctionnels ── -->
    <Color x:Key="AccentColor">#C8643C</Color>
    <Color x:Key="AccentHoverColor">#B0532E</Color>
    <Color x:Key="AccentPressedColor">#984525</Color>
    <Color x:Key="AccentTintColor">#F3E2D8</Color>
    <Color x:Key="AccentColor2">#C8643C</Color>    <!-- (ex-cyan) → accent -->
    <Color x:Key="VioletColor">#C8643C</Color>     <!-- (ex-violet) → accent -->
    <Color x:Key="GreenColor">#5E7150</Color>      <!-- autoriser (sauge) -->
    <Color x:Key="DenyColor">#B0473A</Color>       <!-- refuser (brique) -->
    <Color x:Key="AmberColor">#B07D27</Color>      <!-- avertissement (ocre) -->
    <Color x:Key="SelectionColor">#F3E2D8</Color>  <!-- sélection = accent.tint -->

    <!-- ── Brosses unies ── -->
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="Card2Brush" Color="{StaticResource Card2Color}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource TertiaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource AccentColor2}" />
    <SolidColorBrush x:Key="VioletBrush" Color="{StaticResource VioletColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="AccentTintBrush" Color="{StaticResource AccentTintColor}" />
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}" />
    <SolidColorBrush x:Key="DenyBrush" Color="{StaticResource DenyColor}" />
    <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource AmberColor}" />
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}" />
    <SolidColorBrush x:Key="HeaderTextBrush" Color="{StaticResource HeaderTextColor}" />

    <!-- Anneau de focus (corail translucide) -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#52C8643C" />

    <!-- ── Brosses « façade » des anciens dégradés : désormais PLATES ── -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource HeaderColor}" />
    <SolidColorBrush x:Key="AccentGradientBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentGradientHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="CardGradientBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="ProgressBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="ProgressGreenBrush" Color="{StaticResource GreenColor}" />

    <!-- ── Glows colorés neutralisés (Opacity 0 = sans effet) ── -->
    <DropShadowEffect x:Key="GlowAccent" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <DropShadowEffect x:Key="GlowCyan" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <DropShadowEffect x:Key="GlowViolet" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <DropShadowEffect x:Key="GlowGreen" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <!-- Seule ombre conservée : douce, pour les éléments flottants (popups, dialogues) -->
    <DropShadowEffect x:Key="GlowSoft" Color="#2E2A22" BlurRadius="26" ShadowDepth="6" Opacity="0.18" />

    <!-- Logos pour fond clair : versions NOIRES (« dark ») -->
    <BitmapImage x:Key="LogoTexteImage" UriSource="pack://application:,,,/MAAT.App;component/Assets/logo_texte_dark.png" />
    <BitmapImage x:Key="LogoSymbolImage" UriSource="pack://application:,,,/MAAT.App;component/Assets/symbol_dark.png" />
</ResourceDictionary>
