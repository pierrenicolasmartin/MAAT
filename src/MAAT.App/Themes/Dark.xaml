<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ════════════════════════════════════════════════════════════
         MAAT — Thème INK (sombre)
         Encre chaude near-black, accent corail. Mêmes CLÉS que Paper.
         ════════════════════════════════════════════════════════════ -->

    <!-- ── Fond / surfaces ── -->
    <Color x:Key="BgColor">#16150F</Color>
    <Color x:Key="CardColor">#1E1D16</Color>
    <Color x:Key="Card2Color">#262420</Color>
    <Color x:Key="BorderColor">#332F25</Color>
    <Color x:Key="BorderStrongColor">#46402F</Color>
    <Color x:Key="HeaderColor">#1B1A13</Color>

    <!-- ── Texte ── -->
    <Color x:Key="TextColor">#ECE7DA</Color>
    <Color x:Key="MutedColor">#A8A294</Color>
    <Color x:Key="TertiaryColor">#746F62</Color>
    <Color x:Key="HeaderTextColor">#ECE7DA</Color>

    <!-- ── Accent unique + fonctionnels ── -->
    <Color x:Key="AccentColor">#D8825C</Color>
    <Color x:Key="AccentHoverColor">#E2926E</Color>
    <Color x:Key="AccentPressedColor">#C0704C</Color>
    <Color x:Key="AccentTintColor">#3A2A20</Color>
    <Color x:Key="AccentColor2">#D8825C</Color>
    <Color x:Key="VioletColor">#D8825C</Color>
    <Color x:Key="GreenColor">#9DB37F</Color>
    <Color x:Key="DenyColor">#D98E80</Color>
    <Color x:Key="AmberColor">#D2A24A</Color>
    <Color x:Key="SelectionColor">#3A2A20</Color>

    <!-- ── Brosses unies ── -->
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="Card2Brush" Color="{StaticResource Card2Color}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource TertiaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource AccentColor2}" />
    <SolidColorBrush x:Key="VioletBrush" Color="{StaticResource VioletColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="AccentTintBrush" Color="{StaticResource AccentTintColor}" />
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}" />
    <SolidColorBrush x:Key="DenyBrush" Color="{StaticResource DenyColor}" />
    <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource AmberColor}" />
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}" />
    <SolidColorBrush x:Key="HeaderTextBrush" Color="{StaticResource HeaderTextColor}" />

    <SolidColorBrush x:Key="FocusRingBrush" Color="#66D8825C" />

    <!-- ── Brosses « façade » des anciens dégradés : PLATES ── -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource HeaderColor}" />
    <SolidColorBrush x:Key="AccentGradientBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentGradientHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="CardGradientBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="ProgressBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="ProgressGreenBrush" Color="{StaticResource GreenColor}" />

    <!-- ── Glows neutralisés ── -->
    <DropShadowEffect x:Key="GlowAccent" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <DropShadowEffect x:Key="GlowCyan" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <DropShadowEffect x:Key="GlowViolet" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <DropShadowEffect x:Key="GlowGreen" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <DropShadowEffect x:Key="GlowSoft" Color="#000000" BlurRadius="28" ShadowDepth="6" Opacity="0.45" />

    <!-- Logos pour fond sombre : versions BLANCHES (« light ») -->
    <BitmapImage x:Key="LogoTexteImage" UriSource="pack://application:,,,/MAAT.App;component/Assets/logo_texte_light.png" />
    <BitmapImage x:Key="LogoSymbolImage" UriSource="pack://application:,,,/MAAT.App;component/Assets/symbol_light.png" />
</ResourceDictionary>
